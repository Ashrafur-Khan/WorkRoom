{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./.test-build",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "types": ["chrome", "node"]
  },
  "include": ["src"]
}
