{
  "manifest_version": 3,
  "name": "WorkRoom",
  "version": "0.0.1",
  "permissions": ["storage", "tabs", "notifications", "alarms", "offscreen", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "description": "WorkRoom – focus sessions with goals and timers.",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": "workicon.png",
    "default_title": "WorkRoom"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "css": ["assets/content.css"] 
    }
  ]
}
